{
  "name": "@midcurve/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing Midcurve Finance portfolio data to Claude (read-only)",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "midcurve-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@midcurve/api-shared": "workspace:*",
    "@midcurve/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "pino": "^10.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
