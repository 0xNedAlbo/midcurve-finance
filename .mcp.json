{
  "mcpServers": {
    "blockchain": {
      "type": "stdio",
      "command": "python3",
      "args": ["mcp/blockchain/server.py"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics"
      ]
    }
  }
}
