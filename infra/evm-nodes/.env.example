# =============================================================================
# Ethereum Full Node Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
#
# IMPORTANT: Generate the JWT secret before starting:
#   ./generate-jwt.sh

# -----------------------------------------------------------------------------
# Reth (Execution Client)
# -----------------------------------------------------------------------------

# Docker image — pin to a specific version for stability
RETH_IMAGE=ghcr.io/paradigmxyz/reth:v1.9.3

# HTTP RPC port
RETH_HTTP_PORT=8545

# WebSocket RPC port
RETH_WS_PORT=8546

# Engine API port (internal, used by Lighthouse)
RETH_ENGINE_PORT=8551

# P2P port
RETH_P2P_PORT=30303

# Host bind address for RPC/WS ports
# 127.0.0.1 = local access only (recommended if app is on the same server)
# 0.0.0.0   = all interfaces (use firewall rules to restrict access)
RPC_BIND_ADDRESS=127.0.0.1

# Maximum gas limit for eth_call / eth_estimateGas
RETH_RPC_GAS_CAP=50000000

# -----------------------------------------------------------------------------
# Lighthouse (Consensus Client)
# -----------------------------------------------------------------------------

# Docker image
LIGHTHOUSE_IMAGE=sigp/lighthouse:v8.1.2

# Beacon API port
LIGHTHOUSE_HTTP_PORT=5052

# P2P port
LIGHTHOUSE_P2P_PORT=9000

# Checkpoint sync URL for fast initial sync
# Public providers: https://eth-clients.github.io/checkpoint-sync-endpoints/
LIGHTHOUSE_CHECKPOINT_SYNC_URL=https://beaconstate.ethstaker.cc

# Target number of peers
LIGHTHOUSE_TARGET_PEERS=80

# -----------------------------------------------------------------------------
# Arbitrum One (Nitro)
# -----------------------------------------------------------------------------

# Docker image — pin to a specific version for stability
ARBITRUM_NITRO_IMAGE=offchainlabs/nitro-node:v3.9.7-75e084e

# Parent chain (L1) RPC URL — uses local Reth container
ARBITRUM_PARENT_CHAIN_URL=http://ethereum-reth:8545

# Parent chain beacon API URL (for blob data post-Dencun) — uses local Lighthouse container
ARBITRUM_BEACON_URL=http://ethereum-lighthouse:5052

# HTTP RPC port
ARBITRUM_HTTP_PORT=8547

# WebSocket RPC port
ARBITRUM_WS_PORT=8548

# Metrics port
ARBITRUM_METRICS_PORT=6070

# -----------------------------------------------------------------------------
# API Gateway (Caddy)
# -----------------------------------------------------------------------------

# Secret path component for Caddy reverse proxy
# Generate with `openssl rand -base64 16 | tr -d '=/+' | head -c 22`
API_KEY=

